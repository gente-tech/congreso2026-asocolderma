{% set hay_filtros = false %}

{% set universidad = view.exposed_raw_input.field_universidad_target_id|default(view.exposed_raw_input.field_universidad_principal_target_id|default('')) %}
{% set tipo_programa = view.exposed_raw_input.field_tipo_de_programa_target_id|default(view.exposed_raw_input.tipo_programa_docente|default('')) %}
{% set title = view.exposed_raw_input.title|default('') %}

{% if title|trim != '' %}
  {% set hay_filtros = true %}
{% endif %}

{% if universidad != '' and universidad != 'All' %}
  {% set hay_filtros = true %}
{% endif %}

{% if tipo_programa != '' and tipo_programa != 'All' %}
  {% set hay_filtros = true %}
{% endif %}

<section class="du-generic-swiper du-swiper-program">
  <div class="du-generic-swiper__container du-swiper-program__container">
    <div class="du-generic-swiper__header">
      {% if hay_filtros %}
        <h3>Mostrando <span>{{ view.total_rows }} {{ view.total_rows == 1 ? 'Docente' : 'Docentes' }}</span></h3>
      {% else %}
        <h3>Docentes <span>Recomendados</span></h3>
      {% endif %}
    </div>

    {% if rows %}
      <div class="du-programs-container">
        {% for row in rows %}
          {% set docente = row.docente_entity %}
          {% set programas = row.programas_relacionados|default([]) %}
          {% set docente_url = row.docente_url|default(path('entity.node.canonical', {'node': docente.id()})) %}
          {% set nombre = docente ? docente.label() : '' %}
          {% set especialidad = '' %}
          {% set universidad_label = '' %}
          {% set perfil = '' %}

          {% if docente and docente.hasField('field_especialidad') and not docente.field_especialidad.isEmpty %}
            {% set especialidad = docente.field_especialidad.entity ? docente.field_especialidad.entity.label() : docente.field_especialidad.value %}
          {% endif %}

          {% if docente and docente.hasField('field_universidad_principal') and not docente.field_universidad_principal.isEmpty %}
            {% set universidad_label = docente.field_universidad_principal.entity ? docente.field_universidad_principal.entity.label() : docente.field_universidad_principal.value %}
          {% elseif docente and docente.hasField('field_universidad') and not docente.field_universidad.isEmpty %}
            {% set universidad_label = docente.field_universidad.entity ? docente.field_universidad.entity.label() : docente.field_universidad.value %}
          {% endif %}

          {% if docente and docente.hasField('field_perfil_profesional') and not docente.field_perfil_profesional.isEmpty %}
            {% set perfil = docente.field_perfil_profesional.value %}
          {% endif %}

          <div class="du-programs-item">

            <article class="du-card__diplomat du-card-docente">
              <div class="du-card__diplomat-content">
                <div class="du-card-docente__top">
      
                  <div class="du-card-docente__heading">
                    <h3 class="du-card__diplomat-title">{{ nombre }}</h3>
                    {% if especialidad != '' %}
                      <p class="du-card__diplomat-description">{{ especialidad }}</p>
                    {% endif %}
                  </div>
                </div>

                <div class="du-card__diplomat-info du-card-docente__info-list">
                  {% if universidad_label != '' %}
                    <div class="du-card__diplomat-info-item">
                      <svg width="15" height="13" viewBox="0 0 15 13" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M7.5 1.99457C7.5 1.99457 4 -1.00543 0.5 1.49457V12.4946C4 9.99457 7.5 12.4946 7.5 12.4946M7.5 1.99457C7.5 1.99457 11 -1.00543 14.5 1.49457V12.4946C11 9.99457 7.5 12.4946 7.5 12.4946M7.5 1.99457V12.4946" stroke="#007BE3" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                      <span class="du-card__diplomat-info-text">{{ universidad_label }}</span>
                    </div>
                  {% endif %}

                  <div class="du-card__diplomat-info-item du-card-docente__programs-title">
                    <svg width="15" height="13" viewBox="0 0 15 13" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M7.5 1.99457C7.5 1.99457 4 -1.00543 0.5 1.49457V12.4946C4 9.99457 7.5 12.4946 7.5 12.4946M7.5 1.99457C7.5 1.99457 11 -1.00543 14.5 1.49457V12.4946C11 9.99457 7.5 12.4946 7.5 12.4946M7.5 1.99457V12.4946" stroke="#007BE3" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span class="du-card__diplomat-info-text">Programas:</span>
                  </div>
                </div>

                {% if programas %}
                  <div class="du-card-docente__programas-tags">
                    {% for programa in programas %}
                      <h5>{{ programa.title }}</h5>
                      <h5>{{ programa.url }}</h5>
                      <h5>{{ programa.tipo_programa }}</h5>
                      <h5>{{ programa.tipo_programa_color }}</h5>
                    {% endfor %}
                  </div>
                {% endif %}

                {% if perfil != '' %}
                  <p class="du-card__diplomat-description du-card-docente__bio">{{ perfil|striptags|trim }}</p>
                {% endif %}

                <a href="{{ docente_url }}" class="du-card__diplomat-btn">Ver detalle</a>
              </div>
            </article>


      <article class="du-card__expert">
        <div class="du-card__expert-main">
          {% if docente and docente.hasField('field_foto_docente') and docente.field_foto_docente.entity %}
            <img src="{{ file_url(docente.field_foto_docente.entity.uri.value) }}" alt="{{ nombre }}" class="du-card__expert-img">
          {% endif %}

          <div class="du-card__expert-intro">
            <h3 class="du-card__expert-title">Dr. Alejandro Martínez</h3>
            <p class="du-card__expert-role">Dermatólogo Oncólogo</p>
          </div>
        </div>

        <div class="du-card__expert-uni">
          <svg
            width="21"
            height="21"
            viewBox="0 0 21 21"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M2.0432 7.26354V14.6632M1.28453 6.70077C0.746301 6.44295 0.746301 5.74737 1.28453 5.48955C1.99023 5.1515 3.0445 4.67169 4.53573 4.0505C6.60765 3.18746 8.02295 2.67571 8.78278 2.41634C9.21066 2.26975 9.67516 2.26975 10.103 2.41634C10.8625 2.67571 12.2786 3.18746 14.3501 4.0505C15.8417 4.67169 16.8956 5.1515 17.6017 5.48955C18.1391 5.74737 18.1391 6.44295 17.6017 6.70077C16.8956 7.03882 15.8413 7.51863 14.3501 8.13982C12.2782 9.00286 10.8629 9.51461 10.103 9.77399C9.67516 9.92057 9.21066 9.92057 8.78278 9.77399C8.02333 9.51461 6.60726 9.00286 4.53573 8.13982C3.04411 7.51824 1.99023 7.03882 1.28453 6.70077Z"
              stroke="#007BE3"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
            <path
              d="M4.41985 8.09106C4.39247 8.61521 4.37923 9.14 4.38013 9.66487C4.38013 10.8699 4.44205 11.6266 4.50281 12.0795C4.55616 12.4752 4.78283 12.8117 5.13646 12.9967C5.82034 13.355 7.20954 13.8843 9.44309 13.8843C11.6766 13.8843 13.0658 13.3554 13.7497 12.9971C14.1033 12.8121 14.33 12.4756 14.3834 12.0803C14.4441 11.627 14.506 10.8702 14.506 9.66565C14.507 9.14065 14.4937 8.61573 14.4663 8.09145M3.21175 15.8316C3.21175 16.1414 3.08865 16.4386 2.86954 16.6577C2.65043 16.8768 2.35325 16.9999 2.04338 16.9999C1.7335 16.9999 1.43632 16.8768 1.21721 16.6577C0.998096 16.4386 0.875 16.1414 0.875 15.8316C0.875 15.5217 0.998096 15.2245 1.21721 15.0054C1.43632 14.7863 1.7335 14.6632 2.04338 14.6632C2.35325 14.6632 2.65043 14.7863 2.86954 15.0054C3.08865 15.2245 3.21175 15.5217 3.21175 15.8316Z"
              stroke="#007BE3"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
          <span>Universidad Nacional de Colombia</span>
        </div>

        <div class="du-card__expert-uni">
          <svg
            width="15"
            height="13"
            viewBox="0 0 15 13"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M7.5 1.99463C7.5 1.99463 4 -1.00537 0.5 1.49463V12.4946C4 9.99463 7.5 12.4946 7.5 12.4946M7.5 1.99463C7.5 1.99463 11 -1.00537 14.5 1.49463V12.4946C11 9.99463 7.5 12.4946 7.5 12.4946M7.5 1.99463V12.4946"
              stroke="#007BE3"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
          <span>Programas: </span>
        </div>
        <div class="du-card__expert-tags">
          <span>Diplomado en Dermatología</span>
        </div>

        <div class="du-card__expert-detail">
          <p>
            Especialista en cirugía micrográfica de Mohs con más de 15 años de
            experiencia clínica en el tratamiento de carcinomas.
          </p>
        </div>

        <div class="du-card__expert-footer">
          <a href="#" class="du-link-more">Ver detalle</a>
        </div>
      </article>

          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="du-generic-swiper__header">
        <h3 class="du-programs-message">Ups, no hay resultados <span>por ahora.</span></h3>
      </div>
    {% endif %}
  </div>
</section>
