	<main class="du-main">

		<section class="du-hero">
			<div class="du-hero__container">
				<div class="du-hero__bg" style="
              background-image: url(&quot;https://images.unsplash.com/photo-1576091160550-2173dba999ef?q=80&w=2070&quot;);
            "></div>
				<div class="du-hero__overlay"></div>
				<div class="du-hero__wrapper">
					<div class="du-hero__content">
						<h1 class="du-hero__title">
							<span>Eleva tu carrera </span> con DermaU
						</h1>
						<div class="du-hero__text">
							<p>
								Somos la plataforma de educación dermatológica líder en Colombia, respaldada por la
								Asociación Colombiana de Dermatología y Cirugía Dermatológica. Formamos a los
								profesionales que transforman la salud de la piel.
							</p>
						</div>
						<div class="du-hero__actions">
							<a href="#" class="du-btn du-btn--primary">Ver programas <span
									class="du-icon__next"></span></a>
						</div>
					</div>
				</div>
			</div>

			<div class="du-float-chat">
				<a href="#" class="du-float-chat__link">
